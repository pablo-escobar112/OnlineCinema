<Window x:Class="OnlineCinema.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Онлайн-кинотеатр" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen" Background="#f5f6fa">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="12" CornerRadius="8" Margin="0,0,0,12">
            <WrapPanel>
                <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                <ComboBox x:Name="FilterCombo" Width="170" SelectionChanged="FilterChanged" Margin="0,0,15,0"/>
                <Button Content="Все фильмы" Click="ShowAll_Click" Margin="3" 
                        Background="#3498db" Foreground="White" Height="30" Width="110"/>
                <Button Content="Избранное" Click="ShowFavorites_Click" Margin="3" 
                        Background="#e67e22" Foreground="White" Height="30" Width="100"/>
                <Button Content="История" Click="ShowHistory_Click" Margin="3" 
                        Background="#2ecc71" Foreground="White" Height="30" Width="90"/>
                <Button Content="Подписка" Click="ShowSubscription_Click" Margin="3" 
                        Background="#9b59b6" Foreground="White" Height="30" Width="100"/>
                <Button Content="Рекомендации" Click="ShowRecommendations_Click" Margin="3" 
                        Background="#e74c3c" Foreground="White" Height="30" Width="120"/>
            </WrapPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="MoviesPanel" HorizontalAlignment="Center"/>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="8" CornerRadius="5" Margin="0,8,0,0">
            <TextBlock x:Name="StatusText" Text="Готово"/>
        </Border>
    </Grid>
</Window>