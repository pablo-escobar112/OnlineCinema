<UserControl x:Class="OnlineCinema.App.Controls.FilmCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="460" Width="250">
    <Border Background="White" BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="12" Margin="8">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" Opacity="0.2" BlurRadius="10"/>
        </Border.Effect>
        <StackPanel>

            <!-- ПОСТЕР -->
            <Border Height="180" CornerRadius="12,12,0,0" ClipToBounds="True" Background="#2c3e50">
                <Grid>
                    <Image x:Name="PosterImage" Stretch="UniformToFill"/>

                    <Border Background="#99000000" VerticalAlignment="Bottom" Padding="10,6">
                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15" FontWeight="Bold"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="45"/>
                    </Border>

                    <Border Background="#e74c3c" CornerRadius="12" Padding="7,3"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                        <TextBlock Text="{Binding AgeRating, StringFormat={}{0}+}"
                                   Foreground="White" FontSize="12" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ИНФОРМАЦИЯ -->
            <StackPanel Margin="12,10">
                <Border Background="#3498db" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding GenreName}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                </Border>

                <StackPanel Margin="0,8,0,0">
                    <TextBlock FontSize="13" Margin="0,3,0,0">
                        <Run Text="📅 "/><Run Text="{Binding Year, StringFormat=Год: {0}}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,3,0,0">
                        <Run Text="⏱ "/><Run Text="{Binding Duration, StringFormat={}{0} мин}" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,8,0,0"
                           Foreground="#666" FontSize="11" MaxHeight="40" TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Description}"/>

                <!-- Отладочный текст -->
                <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="9" TextWrapping="Wrap" Margin="0,5,0,0"/>

                <!-- Кнопки -->
                <StackPanel Margin="0,8,0,0">
                    <Button Content="⭐ В избранное" Tag="{Binding Id}" Click="AddToFavorites_Click"
                            Background="#f39c12" Foreground="White" Height="32" FontSize="12"/>
                    <Button Content="ℹ Подробнее" Tag="{Binding Id}" Click="Details_Click"
                            Background="#3498db" Foreground="White" Height="32" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>