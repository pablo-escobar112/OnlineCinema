<Window x:Class="OnlineCinema.App.CollectionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мои подборки" Height="550" Width="700"
        WindowStartupLocation="CenterOwner" Background="#f5f6fa">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка создания -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="📁 Мои подборки" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="+ Создать подборку" Click="CreateCollection_Click" 
                    Background="#27ae60" Foreground="White" Height="30" Width="160" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Список подборок -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl x:Name="CollectionsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Padding="15" Margin="0,0,0,8" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#666" Margin="0,3,0,0"/>
                                    <TextBlock Margin="0,3,0,0">
                                        <Run Text="Фильмов: "/><Run Text="{Binding MovieCount}" FontWeight="Bold"/>
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1" Content="📂 Открыть" Tag="{Binding Id}" Click="OpenCollection_Click"
                                        Background="#3498db" Foreground="White" Margin="5,0"/>
                                <Button Grid.Column="2" Content="🗑" Tag="{Binding Id}" Click="DeleteCollection_Click"
                                        Background="#e74c3c" Foreground="White" Width="40"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>