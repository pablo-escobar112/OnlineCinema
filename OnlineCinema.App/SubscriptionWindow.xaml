<Window x:Class="OnlineCinema.App.SubscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление подпиской" Height="450" Width="550"
        WindowStartupLocation="CenterOwner" Background="#f5f6fa">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="ТЕКУЩАЯ ПОДПИСКА" FontWeight="Bold" FontSize="14"/>
                <TextBlock x:Name="CurrentSubInfo" Text="Загрузка..." Margin="0,8,0,0"/>
                <TextBlock x:Name="StatusInfo" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBlock x:Name="DaysInfo" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="ДОСТУПНЫЕ ТАРИФЫ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="2">
            <ItemsControl x:Name="TariffsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Padding="15" Margin="0,0,0,8" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Margin="0,5,0,0">
                                        <Run Text="{Binding Price, StringFormat={}{0:F2}}"/>
                                        <Run Text=" ₽"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DurationDays, StringFormat=Срок: {0} дней}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Оформить" Tag="{Binding Id}"
                                        Click="ActivateSubscription_Click" Width="100" Height="30"
                                        Background="#9b59b6" Foreground="White"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="3" Content="Закрыть" Click="Close_Click" Width="100" Height="30"
                HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
</Window>