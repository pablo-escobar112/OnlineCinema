<Window x:Class="OnlineCinema.App.MovieSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выберите фильм" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" Background="#f5f6fa">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="MoviesListBox" Grid.Row="0" DisplayMemberPath="Title"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" Click="Add_Click" Width="100" Height="30"
                    Background="#27ae60" Foreground="White"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80" Height="30" Margin="5,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>